{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sheetmetal V1 Panel Definition",
  "type": "object",
  "required": ["panel_id", "width_mm", "height_mm", "depth_mm", "evidence_ids", "status"],
  "properties": {
    "panel_id": {"type": "string"},
    "width_mm": {"type": "number"},
    "height_mm": {"type": "number"},
    "depth_mm": {"type": "number"},
    "compartments": {"type": "array"},
    "doors": {"type": "array"},
    "mounting_surfaces": {"type": "array"},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string"}
  }
}
