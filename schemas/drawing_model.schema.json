{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Drawing Model",
  "type": "object",
  "required": ["schema_version", "project_id", "job_spec_hash", "units", "panels", "renderer_visibility"],
  "properties": {
    "schema_version": {"type": "string"},
    "project_id": {"type": "string"},
    "job_spec_hash": {"type": "string"},
    "units": {"type": "string"},
    "model_version": {"type": "string"},
    "panels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["panel_id", "width", "height"],
        "properties": {
          "panel_id": {"type": "string"},
          "width": {"type": "number"},
          "height": {"type": "number"},
          "material": {"type": ["string", "null"]},
          "thickness": {"type": ["number", "null"]},
          "devices": {"type": "array"},
          "cutouts": {"type": "array"},
          "verification_status": {"type": "string"}
        }
      }
    },
    "renderer_visibility": {"type": "object"},
    "unresolved_regions": {"type": "array"},
    "provenance": {"type": "array"}
  }
}

