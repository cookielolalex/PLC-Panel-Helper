{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reference Page Classification",
  "type": "object",
  "required": [
    "schema_version",
    "detector_version",
    "task_id",
    "project_id",
    "neutral_reference_file_id",
    "page_number",
    "page_count",
    "page_width_pt",
    "page_height_pt",
    "orientation",
    "page_classification",
    "project_identity_status",
    "classification_method",
    "confidence",
    "evidence_ids",
    "signals_used",
    "minimization"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "detector_version": {"type": "string"},
    "task_id": {"type": "string"},
    "project_id": {"type": "string"},
    "neutral_reference_file_id": {"type": "string"},
    "page_number": {"type": "integer", "minimum": 1},
    "page_count": {"type": "integer", "minimum": 1},
    "page_width_pt": {"type": "number", "minimum": 1},
    "page_height_pt": {"type": "number", "minimum": 1},
    "orientation": {"enum": ["PORTRAIT", "LANDSCAPE", "SQUARE_OR_UNKNOWN"]},
    "page_classification": {
      "enum": [
        "PRODUCTION_DRAWING",
        "SHEETMETAL_DRAWING",
        "PUNCH_DRAWING",
        "ELECTRICAL_DRAWING",
        "SOURCE_DOCUMENT",
        "COVER_OR_INDEX",
        "REVISION_NOTICE",
        "OTHER_DRAWING",
        "UNCLASSIFIED"
      ]
    },
    "project_identity_status": {
      "enum": [
        "CONFIRMED",
        "CONFLICT",
        "NOT_FOUND",
        "NOT_REQUIRED_FOR_NON_TARGET"
      ]
    },
    "revision_identity": {"type": ["string", "null"]},
    "classification_method": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "signals_used": {"type": "array", "items": {"type": "string"}},
    "minimization": {
      "type": "object",
      "required": [
        "raw_text_persisted",
        "rendered_image_persisted",
        "title_crop_persisted",
        "absolute_private_path_persisted",
        "drawing_detail_persisted"
      ],
      "properties": {
        "raw_text_persisted": {"type": "boolean"},
        "rendered_image_persisted": {"type": "boolean"},
        "title_crop_persisted": {"type": "boolean"},
        "absolute_private_path_persisted": {"type": "boolean"},
        "drawing_detail_persisted": {"type": "boolean"}
      }
    }
  }
}
