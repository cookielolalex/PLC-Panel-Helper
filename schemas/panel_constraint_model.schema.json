  "properties": {
    "schema_version": {"type": "string"},
    "project_id": {"type": "string"},
    "hard_constraints": {"type": "array", "items": {"type": "string"}},
    "soft_objectives": {"type": "array", "items": {"type": "string"}},
    "placements": {"type": "array"},
    "failed_placements": {"type": "array"},
    "status": {"type": "string"}
  }
}
