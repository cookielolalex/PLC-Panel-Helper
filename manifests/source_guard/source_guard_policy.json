{
  "policy_id": "source_guard_policy_v2_autonomous_eval",
  "policy_version": "source_guard_policy_v2_autonomous_eval",
  "status": "AUTONOMOUS_EVALUATION_ONLY_SOURCE_APPROVAL",
  "allowed_production_state_requires": [
    "explicit_human_approval",
    "current_file_hash_match",
    "current_worksheet_fingerprint_match",
    "sanitized_artifact_created",
    "bundle_verification_pass",
    "no_denied_or_quarantined_dependency"
  ],
  "allowed_eval_state_requires": [
    "deterministic_source_validation",
    "four_independent_specialist_reviews",
    "unanimous_agent_quorum",
    "separate_adjudication",
    "sanitized_bundle_verification",
    "independent_audit"
  ],
  "no_automatic_allowed": true,
  "forbidden_labels": [
    "生管文件",
    "電機施工圖",
    "生管課用圖",
    "生管用圖",
    "鈑金施工圖",
    "沖孔施工圖"
  ],
  "decision_states": [
    "UNREVIEWED",
    "AUTO_DENIED",
    "CANDIDATE",
    "PARSER_REQUIRED",
    "QUARANTINED",
    "SUPERSEDED",
    "AGENT_QUORUM_APPROVED_EVAL",
    "ALLOWED_EVAL",
    "ALLOWED_PRODUCTION",
    "NEEDS_HUMAN_REVIEW",
    "HUMAN_APPROVED",
    "HUMAN_DENIED",
    "ALLOWED"
  ],
  "manual_edit_gate": "SUPERSEDED_FOR_EVALUATION_ONLY",
  "production_approval_gate": "EXPLICIT_HUMAN_APPROVAL_REQUIRED",
  "worksheet_fingerprint": {
    "algorithm": "SHA-256 over sorted UTF-8 JSON payload",
    "payload_fields": [
      "sheet_name",
      "sheet_visibility",
      "workbook_sheet_count",
      "used_range_dimensions",
      "normalized_visible_cell_content",
      "merged_ranges",
      "formula_locations",
      "defined_names_touching_sheet",
      "identity_like_cells"
    ]
  }
}
