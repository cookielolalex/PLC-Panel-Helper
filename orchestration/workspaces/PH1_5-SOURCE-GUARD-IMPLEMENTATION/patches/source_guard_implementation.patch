+        "detected_customer": "Synthetic customer",
+        "detected_project_name": "Synthetic project",
+        "detected_date": "2026-06-22",
+        "detected_revision": "0",
+        "stale_template_status": "CURRENT_PROJECT_ID_MATCH",
+        "stale_evidence": "",
+        "generator_eligibility": "HUMAN_REVIEW_REQUIRED",
+        "approved_by": "",
+        "approval_time": "",
+        "parse_status": "PARSED",
+        "notes": "",
