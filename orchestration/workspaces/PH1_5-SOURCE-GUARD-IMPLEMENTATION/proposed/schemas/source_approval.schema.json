{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Approval",
  "type": "object",
  "required": [
    "approval_id",
    "created_at",
    "approved_by",
    "signed_human_decision",
    "bound_inputs",
    "decisions"
  ],
  "properties": {
    "approval_id": {"type": "string"},
    "created_at": {"type": "string"},
    "approved_by": {"type": "string"},
    "signed_human_decision": {
      "type": "object",
      "required": ["signer", "signed_at", "statement", "signature_sha256"],
      "properties": {
        "signer": {"type": "string"},
        "signed_at": {"type": "string"},
        "statement": {"type": "string"},
        "signature_sha256": {"type": "string"}
      }
    },
    "bound_inputs": {
      "type": "object",
      "required": ["file_role_index_sha256", "workbook_sheet_index_sha256"],
      "properties": {
        "file_role_index_sha256": {"type": "string"},
        "workbook_sheet_index_sha256": {"type": "string"},
        "source_roots_sha256": {"type": "string"},
        "review_batch_sha256": {"type": "string"}
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "decision_id",
          "item_type",
          "item_id",
          "decision",
          "current_row_sha256",
          "rationale"
        ],
        "properties": {
          "decision_id": {"type": "string"},
          "item_type": {"enum": ["file", "worksheet"]},
          "item_id": {"type": "string"},
          "decision": {
            "enum": [
              "ALLOW_GENERATOR_INPUT",
              "REJECT_GENERATOR_INPUT",
              "REQUEST_MORE_INFO"
            ]
          },
          "current_row_sha256": {"type": "string"},
          "effective_project_id": {"type": "string"},
          "rationale": {"type": "string"}
        }
      }
    }
  }
}

