+
+def _add_hit(hits: list[dict[str, str]], path: str, term: str, location: str, category: str) -> None:
+    hits.append({"path": path, "term": term, "location": location, "category": category})
+
+
+def _scan_text(
+    hits: list[dict[str, str]],
+    path: str,
+    text: str,
+    location: str,
+    *,
+    project_id: str | None,
+    customer_id: str | None,
+    source_root_canaries: list[str],
+) -> None:
+    for term in detect_forbidden_text(text):
+        _add_hit(hits, path, term, location, "forbidden_term")
+    for term in detect_source_root_leaks(text, source_root_canaries):
+        _add_hit(hits, path, term, location, "source_root_path_leak")
+    for term in detect_target_output_names(text):
+        _add_hit(hits, path, term, location, "target_output_name_leak")
+    if FORMULA_RE.search(text):
+        _add_hit(hits, path, "formula", location, "workbook_formula")
+    if DEFINED_NAME_RE.search(text):
+        _add_hit(hits, path, "definedName", location, "workbook_named_range")
+    for state in HIDDEN_SHEET_RE.findall(text):
+        _add_hit(hits, path, state, location, "workbook_hidden_sheet")
+    if "TargetMode=\"External\"" in text or "externalLink" in text:
+        _add_hit(hits, path, "externalLink", location, "workbook_external_link")
+    if project_id:
+        for found in PROJECT_ID_RE.findall(text):
+            if found != project_id:
+                _add_hit(hits, path, found, location, "stale_project_id")
+    if customer_id:
+        for found in CUSTOMER_ID_RE.findall(text):
+            if found != customer_id:
+                _add_hit(hits, path, found, location, "stale_customer_id")
+
+
+def _is_relative_to(path: Path, root: Path) -> bool:
+    try:
+        path.relative_to(root)
+        return True
+    except ValueError:
+        return False
+
+
+def _is_reparse_point(path: Path) -> bool:
+    if path.is_symlink():
+        return True
+    attrs = getattr(path.stat(follow_symlinks=False), "st_file_attributes", 0)
+    return bool(attrs & getattr(stat, "FILE_ATTRIBUTE_REPARSE_POINT", 0))
+
+
+def _walk_json(value: Any, path: str = "$") -> list[tuple[str, Any]]:
+    rows = [(path, value)]
+    if isinstance(value, dict):
+        for key, child in value.items():
+            rows.extend(_walk_json(child, f"{path}.{key}"))
+    elif isinstance(value, list):
+        for index, child in enumerate(value):
+            rows.extend(_walk_json(child, f"{path}[{index}]"))
+    return rows
+
+
+def _scan_manifest_semantics(
+    hits: list[dict[str, str]],
+    manifest: Any,
+    bundle_root: Path,
+) -> None:
+    for json_path, value in _walk_json(manifest):
+        if isinstance(value, dict):
+            superseded = value.get("superseded_by") or value.get("superseded_by_file_id")
+            status = str(value.get("supersession_status", "")).upper()
+            if superseded or "SUPERSEDED" in status:
+                _add_hit(hits, json_path, str(superseded or status), "manifest", "superseded_source")
+
+            approval_scope = str(value.get("approval_scope", "")).strip().lower()
+            if value.get("bulk_approval") is True or approval_scope == "bulk":
+                _add_hit(hits, json_path, "bulk_approval", "manifest", "bulk_approval")
+            for key in ("decision_id", "approver", "approved_by", "signed_by", "signature"):
+                if key in value and not str(value.get(key, "")).strip():
+                    _add_hit(hits, json_path, key, "manifest", "blank_decision")
+            if value.get("approved") is True and not (
+                value.get("signature") or value.get("signed_hash") or value.get("decision_hash")
+            ):
+                _add_hit(hits, json_path, "missing_signature", "manifest", "approval_tampering")
+            if value.get("tampered") is True:
+                _add_hit(hits, json_path, "tampered", "manifest", "approval_tampering")
+
+            candidate_path = value.get("bundle_path") or value.get("relative_path") or value.get("path")
+            expected_hash = value.get("sha256") or value.get("hash")
+            if candidate_path and expected_hash:
+                candidate = bundle_root / str(candidate_path)
+                if candidate.exists() and candidate.is_file():
+                    actual = sha256_file(candidate)
+                    if actual.upper() != str(expected_hash).upper():
+                        _add_hit(hits, str(candidate_path), str(expected_hash), "manifest", "mutation_invalidation")
+
+
+def _scan_decision_artifact(hits: list[dict[str, str]], decision_path: Path | None) -> None:
+    if not decision_path:
+        return
+    data = read_json(decision_path)
+    _scan_manifest_semantics(hits, data, decision_path.parent)
+
+
+def _scan_zip_workbook(
+    hits: list[dict[str, str]],
+    path: Path,
+    rel: str,
+    *,
+    project_id: str | None,
+    customer_id: str | None,
+    source_root_canaries: list[str],
+) -> None:
+    try:
+        with zipfile.ZipFile(path) as zf:
+            names = zf.namelist()
+            for name in names:
+                normalized = name.replace("\\", "/")
+                parts = [part for part in normalized.split("/") if part]
+                if normalized.startswith("/") or ".." in parts:
+                    _add_hit(hits, f"{rel}!/{name}", name, "zip_entry", "zip_traversal")
+                if normalized == "xl/vbaProject.bin":
+                    _add_hit(hits, f"{rel}!/{name}", "vbaProject.bin", "zip_entry", "macro_enabled_workbook")
+                if normalized.startswith("xl/externalLinks/"):
+                    _add_hit(hits, f"{rel}!/{name}", "externalLinks", "zip_entry", "workbook_external_link")
+                suffix = Path(normalized).suffix
+                if suffix in TEXT_ENTRY_SUFFIXES and zf.getinfo(name).file_size <= 1024 * 1024:
+                    text = zf.read(name).decode("utf-8", errors="ignore")
+                    _scan_text(
+                        hits,
+                        f"{rel}!/{name}",
+                        text,
+                        "zip_content",
+                        project_id=project_id,
+                        customer_id=customer_id,
+                        source_root_canaries=source_root_canaries,
+                    )
+    except zipfile.BadZipFile:
+        _add_hit(hits, rel, "bad_zip", "content", "uninspectable_workbook")
