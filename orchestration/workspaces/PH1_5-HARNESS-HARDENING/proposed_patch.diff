 def detect_forbidden_text(text: str) -> list[str]:
     return [term for term in FORBIDDEN_TERMS if term in text]
+
+
+def detect_source_root_leaks(text: str, extra_canaries: list[str] | None = None) -> list[str]:
+    terms = SOURCE_ROOT_LEAK_TERMS + [term for term in (extra_canaries or []) if term]
+    return [term for term in terms if term in text]
+
+
+def detect_target_output_names(text: str) -> list[str]:
+    hits = [label for label in TARGET_OUTPUT_LABELS if label in text]
+    if TARGET_OUTPUT_NAME_RE.search(text):
+        hits.append("target_output_name_pattern")
+    return hits
