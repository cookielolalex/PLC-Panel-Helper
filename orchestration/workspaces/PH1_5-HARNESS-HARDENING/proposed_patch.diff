+TEXT_ENTRY_SUFFIXES = {".xml", ".rels", ".txt", ".json", ".csv"}
+FORMULA_RE = re.compile(r"<(?:[A-Za-z0-9_]+:)?f(?:\s|>)", re.IGNORECASE)
+DEFINED_NAME_RE = re.compile(r"<(?:[A-Za-z0-9_]+:)?definedName\b", re.IGNORECASE)
+HIDDEN_SHEET_RE = re.compile(r"<sheet\b[^>]*\bstate=\"(hidden|veryHidden)\"", re.IGNORECASE)
+PROJECT_ID_RE = re.compile(r"(?:project_id|project id|工程編號)\s*[:=]\s*([A-Za-z0-9_-]+)", re.IGNORECASE)
